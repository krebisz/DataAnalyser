<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="clr-namespace:DataVisualiser.UI">
    <Style TargetType="{x:Type ui:ChartTabHost}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ui:ChartTabHost}">
                    <ui:WorkspaceTabHost BodyContent="{TemplateBinding ChartContent}">
                        <ui:WorkspaceTabHost.HeaderContent>
                            <ui:MetricSelectionPanel x:Name="PART_SelectionPanel" />
                        </ui:WorkspaceTabHost.HeaderContent>
                    </ui:WorkspaceTabHost>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
