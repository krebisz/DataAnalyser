<UserControl x:Class="DataVisualiser.UI.MainChartsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DataVisualiser.UI.Charts.Controllers"
             xmlns:ui="clr-namespace:DataVisualiser.UI">
    <UserControl.Resources>
        <Style TargetType="Label" BasedOn="{StaticResource ThemedLabelStyle}" />
        <Style TargetType="Button" BasedOn="{StaticResource ThemedButtonStyle}" />
        <Style TargetType="ComboBox" BasedOn="{StaticResource ThemedComboBoxStyle}" />
        <Style TargetType="DatePicker" BasedOn="{StaticResource ThemedDatePickerStyle}" />
        <Style TargetType="CheckBox" BasedOn="{StaticResource ThemedCheckBoxStyle}" />
        <Style TargetType="RadioButton" BasedOn="{StaticResource ThemedRadioButtonStyle}" />
        <Style TargetType="TextBlock" BasedOn="{StaticResource ThemedTextBlockStyle}" />
        <Style TargetType="Expander" BasedOn="{StaticResource ThemedExpanderStyle}" />
    </UserControl.Resources>
    <ui:ChartTabHost x:Name="ChartTabHost">
        <ui:ChartTabHost.ChartContent>
            <StackPanel x:Name="MainContentPanel"
                        Orientation="Vertical">

                <!-- ========== CHART MAIN ========== -->
                <controls:MainChartController x:Name="MainChartController" />

                <!-- ========== CHART NORMALIZED ========== -->
                <controls:NormalizedChartController x:Name="NormalizedChartController" />

                <!-- ========== CHART DIFFERENCE / RATIO (UNIFIED) ========== -->
                <!-- <controls:DiffRatioChartController x:Name="DiffRatioChartController" /> -->

                <!-- ========== CHART BAR / PIE ========== -->
                <controls:BarPieChartController x:Name="BarPieChartController" />

                <!-- ========== CHART WEEKDAY TREND ========== -->
                <controls:WeekdayTrendChartController x:Name="WeekdayTrendChartController" />

                <!-- ========== CHART DISTRIBUTION ========== -->
                <controls:DistributionChartController x:Name="DistributionChartController" />

                <!-- ========== TRANSFORM DATA PANEL ========== -->
                <controls:TransformDataPanelControllerV2 x:Name="TransformDataPanelController" />

            </StackPanel>
        </ui:ChartTabHost.ChartContent>
    </ui:ChartTabHost>
</UserControl>
