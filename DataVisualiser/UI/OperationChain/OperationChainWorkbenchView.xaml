<UserControl x:Class="DataVisualiser.UI.OperationChain.OperationChainWorkbenchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:DataVisualiser.UI">
    <UserControl.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource ThemedButtonStyle}" />
        <Style TargetType="ComboBox" BasedOn="{StaticResource ThemedComboBoxStyle}" />
        <Style TargetType="DatePicker" BasedOn="{StaticResource ThemedDatePickerStyle}" />
        <Style TargetType="DataGrid" BasedOn="{StaticResource ThemedDataGridStyle}" />
        <Style TargetType="TextBlock" BasedOn="{StaticResource ThemedTextBlockStyle}" />
    </UserControl.Resources>
    <ui:WorkspaceTabHost>
        <ui:WorkspaceTabHost.HeaderContent>
            <Border Padding="10"
                    Background="{DynamicResource ThemeTopBarBackgroundBrush}"
                    BorderBrush="{DynamicResource ThemeOperationPanelBorderBrush}"
                    BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="Operation Chain"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="SummaryText"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource ThemeSecondaryTextBrush}"
                               Text="No operation-chain result is loaded." />
                </StackPanel>
            </Border>
        </ui:WorkspaceTabHost.HeaderContent>

        <Grid Margin="10"
              Background="{DynamicResource ThemeAppBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0,0,0,10"
                    Padding="8"
                    BorderBrush="{DynamicResource ThemeOperationPanelBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="Inputs"
                                   FontWeight="SemiBold"
                                   DockPanel.Dock="Left" />
                        <Button x:Name="AddInputButton"
                                Content="Add input"
                                Padding="10,4"
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right"
                                Click="OnAddInputClicked" />
                    </DockPanel>
                    <StackPanel x:Name="InputRowsPanel" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,0,0,10"
                    Padding="8"
                    BorderBrush="{DynamicResource ThemeOperationPanelBorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Text="Operation" />
                    <ComboBox x:Name="OperationCombo"
                              Grid.Column="1"
                              SelectionChanged="OnOperationChanged" />
                    <TextBlock Grid.Column="2"
                               Margin="12,0,8,0"
                               VerticalAlignment="Center"
                               Text="From" />
                    <DatePicker x:Name="FromDate"
                                Grid.Column="3" />
                    <TextBlock Grid.Column="4"
                               Margin="12,0,8,0"
                               VerticalAlignment="Center"
                               Text="To" />
                    <DatePicker x:Name="ToDate"
                                Grid.Column="5" />
                    <TextBlock Grid.Column="6"
                               Margin="12,0,8,0"
                               VerticalAlignment="Center"
                               Text="Resolution" />
                    <ComboBox x:Name="ResolutionCombo"
                              Grid.Column="7"
                              SelectionChanged="OnResolutionChanged" />
                    <Button x:Name="LoadInputsButton"
                            Grid.Column="8"
                            Margin="12,0,0,0"
                            Padding="12,4"
                            Content="Compute"
                            Click="OnLoadInputsClicked" />
                    <Button x:Name="ExportEvidenceButton"
                            Grid.Column="9"
                            Margin="8,0,0,0"
                            Padding="12,4"
                            Content="Export"
                            Click="OnExportEvidenceClicked" />
                </Grid>
            </Border>

            <Grid Grid.Row="2"
                  ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="ResultGridTitle"
                           Grid.Row="0"
                           Margin="0,0,0,5"
                           FontWeight="SemiBold"
                           Text="Result" />
                <DataGrid x:Name="ResultGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          MaxHeight="{x:Static ui:ChartUiDefaults.TransformGridMaxHeight}"
                          MinWidth="{x:Static ui:ChartUiDefaults.TransformGridMinWidth}"
                          VerticalAlignment="Top"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          CanUserResizeColumns="True"
                          CanUserReorderColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Timestamp"
                                            Binding="{Binding Timestamp}"
                                            Width="Auto"
                                            MinWidth="{x:Static ui:ChartUiDefaults.TransformGridTimestampMinWidth}" />
                        <DataGridTextColumn Header="Raw"
                                            Binding="{Binding Raw}"
                                            Width="Auto"
                                            MinWidth="{x:Static ui:ChartUiDefaults.TransformGridValueMinWidth}" />
                        <DataGridTextColumn Header="Smoothed"
                                            Binding="{Binding Smoothed}"
                                            Width="Auto"
                                            MinWidth="{x:Static ui:ChartUiDefaults.TransformGridValueMinWidth}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <TextBlock x:Name="EvidenceText"
                       Grid.Row="3"
                       Margin="0,10,0,0"
                       Foreground="{DynamicResource ThemeSecondaryTextBrush}"
                       TextWrapping="Wrap" />
        </Grid>
    </ui:WorkspaceTabHost>
</UserControl>
