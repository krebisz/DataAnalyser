<UserControl x:Class="DataVisualiser.UI.OperationChain.OperationChainWorkbenchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:ui="clr-namespace:DataVisualiser.UI">
    <UserControl.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource ThemedButtonStyle}" />
        <Style TargetType="ComboBox" BasedOn="{StaticResource ThemedComboBoxStyle}" />
        <Style TargetType="DatePicker" BasedOn="{StaticResource ThemedDatePickerStyle}" />
        <Style TargetType="DataGrid" BasedOn="{StaticResource ThemedDataGridStyle}" />
        <Style TargetType="TextBlock" BasedOn="{StaticResource ThemedTextBlockStyle}" />
        <Style x:Key="SelectableResultGridCellStyle"
               TargetType="DataGridCell"
               BasedOn="{StaticResource ThemedDataGridCellStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsIncluded}" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource ThemeSecondaryTextBrush}" />
                    <Setter Property="Opacity" Value="0.65" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <ui:WorkspaceTabHost>
        <ui:WorkspaceTabHost.HeaderContent>
            <Border Padding="10"
                    Background="{DynamicResource ThemeTopBarBackgroundBrush}"
                    BorderBrush="{DynamicResource ThemeOperationPanelBorderBrush}"
                    BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="Operation Chain"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="SummaryText"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource ThemeSecondaryTextBrush}"
                               Text="No operation-chain result is loaded." />
                </StackPanel>
            </Border>
        </ui:WorkspaceTabHost.HeaderContent>

        <Grid Margin="10"
              Background="{DynamicResource ThemeAppBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0,0,0,10"
                    Padding="8"
                    BorderBrush="{DynamicResource ThemeOperationPanelBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Inputs"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <TextBlock Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Text="Resolution" />
                            <ComboBox x:Name="ResolutionCombo"
                                      Width="110"
                                      SelectionChanged="OnResolutionChanged" />
                            <TextBlock Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Text="From" />
                            <DatePicker x:Name="FromDate" />
                            <TextBlock Margin="12,0,8,0"
                                       VerticalAlignment="Center"
                                       Text="To" />
                            <DatePicker x:Name="ToDate" />
                            <Button x:Name="ExportEvidenceButton"
                                    Margin="12,0,0,0"
                                    Padding="12,4"
                                    Content="Export"
                                    Click="OnExportEvidenceClicked" />
                            <Button x:Name="ClearButton"
                                    Margin="8,0,0,0"
                                    Padding="12,4"
                                    Content="Clear"
                                    Click="OnClearClicked" />
                            <Button x:Name="AddInputButton"
                                    Margin="8,0,0,0"
                                    Padding="10,4"
                                    Content="Add input"
                                    Click="OnAddInputClicked" />
                        </StackPanel>
                    </Grid>
                    <StackPanel x:Name="InputRowsPanel" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,0,0,10"
                    Padding="8"
                    BorderBrush="{DynamicResource ThemeOperationPanelBorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Text="Equation" />
                    <TextBox x:Name="EquationText"
                             Grid.Column="1"
                             Background="{DynamicResource ThemeInputBackgroundBrush}"
                             BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                             Foreground="{DynamicResource ThemeInputForegroundBrush}"
                             IsReadOnly="True"
                             MinWidth="320"
                             TextWrapping="NoWrap" />
                    <Button x:Name="ClearEquationButton"
                            Grid.Column="2"
                            Margin="8,0,0,0"
                            Padding="12,4"
                            Content="Clear"
                            Click="OnClearEquationClicked" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,0,0,10"
                    Padding="8"
                    BorderBrush="{DynamicResource ThemeOperationPanelBorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Text="Operation" />
                    <ComboBox x:Name="OperationCombo"
                              Grid.Column="1"
                              SelectionChanged="OnOperationChanged" />
                    <TextBlock Grid.Column="2"
                               Margin="12,0,8,0"
                               VerticalAlignment="Center"
                               Text="Input" />
                    <ComboBox x:Name="EquationInputCombo"
                              Grid.Column="3"
                              MinWidth="160" />
                    <Button x:Name="AddEquationTermButton"
                            Grid.Column="4"
                            Margin="12,0,0,0"
                            Padding="12,4"
                            Content="Add"
                            Click="OnAddEquationTermClicked" />
                    <Button x:Name="LoadInputsButton"
                            Grid.Column="5"
                            Margin="12,0,0,0"
                            Padding="12,4"
                            Content="Compute"
                            Click="OnLoadInputsClicked" />
                </Grid>
            </Border>

            <Grid Grid.Row="3"
                  ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="ResultGridTitle"
                           Grid.Row="0"
                           Margin="0,0,0,5"
                           FontWeight="SemiBold"
                           Text="Result" />
                <DataGrid x:Name="ResultGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          CellStyle="{StaticResource SelectableResultGridCellStyle}"
                          MaxHeight="{x:Static ui:ChartUiDefaults.TransformGridMaxHeight}"
                          MinWidth="{x:Static ui:ChartUiDefaults.TransformGridMinWidth}"
                          VerticalAlignment="Top"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          CanUserResizeColumns="True"
                          CanUserReorderColumns="False"
                          KeyDown="OnResultGridKeyDown"
                          PreviewMouseLeftButtonDown="OnResultGridPreviewMouseLeftButtonDown">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Timestamp"
                                            Binding="{Binding Timestamp}"
                                            Width="Auto"
                                            MinWidth="{x:Static ui:ChartUiDefaults.TransformGridTimestampMinWidth}" />
                        <DataGridTextColumn Header="Value"
                                            Binding="{Binding Raw}"
                                            Width="Auto"
                                            MinWidth="{x:Static ui:ChartUiDefaults.TransformGridValueMinWidth}" />
                        <DataGridTextColumn x:Name="SmoothedResultColumn"
                                            Header="Smoothed"
                                            Binding="{Binding Smoothed}"
                                            Width="*"
                                            MinWidth="{x:Static ui:ChartUiDefaults.TransformGridValueMinWidth}" />
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="2"
                        Grid.RowSpan="2"
                        Margin="0,10,0,10"
                        BorderBrush="{DynamicResource ThemePanelBorderBrush}"
                        BorderThickness="1">
                    <StackPanel Orientation="Vertical"
                                Margin="{x:Static ui:ChartUiDefaults.ChartPanelStackMargin}">
                        <Border Background="{DynamicResource ThemePanelHeaderBackgroundBrush}"
                                BorderBrush="{DynamicResource ThemePanelHeaderBorderBrush}"
                                BorderThickness="1"
                                Padding="{x:Static ui:ChartUiDefaults.ChartHeaderPadding}">
                            <Grid Margin="{x:Static ui:ChartUiDefaults.ChartHeaderMargin}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           FontSize="{x:Static ui:ChartUiDefaults.ChartHeaderFontSize}"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           Text="Output Chart" />
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <Button x:Name="OutputChartResetZoomButton"
                                            Content="Reset Zoom"
                                            Margin="{x:Static ui:ChartUiDefaults.ChartHeaderToggleMargin}"
                                            Padding="{x:Static ui:ChartUiDefaults.ChartHeaderTogglePadding}"
                                            Click="OnOutputChartResetZoomClicked" />
                                    <Button x:Name="OutputChartToggleButton"
                                            Content="{x:Static ui:UiDefaults.ToggleHideLabel}"
                                            Margin="{x:Static ui:ChartUiDefaults.ChartHeaderToggleMargin}"
                                            Padding="{x:Static ui:ChartUiDefaults.ChartHeaderTogglePadding}"
                                            Click="OnOutputChartToggleClicked" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <StackPanel x:Name="OutputChartContentPanel"
                                    Orientation="Vertical">
                            <lvc:CartesianChart x:Name="OutputChart"
                                                MinHeight="260"
                                                LegendLocation="Right"
                                                Zoom="{x:Static ui:ChartUiDefaults.DefaultZoom}"
                                                Pan="{x:Static ui:ChartUiDefaults.DefaultPan}"
                                                Hoverable="True"
                                                DisableAnimations="True"
                                                Margin="{x:Static ui:ChartUiDefaults.ChartContentMargin}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock x:Name="EvidenceText"
                       Grid.Row="4"
                       Margin="0,10,0,0"
                       Foreground="{DynamicResource ThemeSecondaryTextBrush}"
                       TextWrapping="Wrap" />
        </Grid>
    </ui:WorkspaceTabHost>
</UserControl>
