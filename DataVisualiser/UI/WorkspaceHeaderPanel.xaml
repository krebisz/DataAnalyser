<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="clr-namespace:DataVisualiser.UI">
    <Style TargetType="{x:Type ui:WorkspaceHeaderPanel}">
        <Setter Property="Margin" Value="10,10,10,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ui:WorkspaceHeaderPanel}">
                    <Border Background="{DynamicResource ThemeTopBarBackgroundBrush}"
                            BorderBrush="{DynamicResource ThemePanelBorderBrush}"
                            BorderThickness="1"
                            Padding="8"
                            CornerRadius="4">
                        <ContentPresenter Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
