<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="clr-namespace:DataVisualiser.UI">
    <Style TargetType="{x:Type ui:WorkspaceTabHost}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ui:WorkspaceTabHost}">
                    <DockPanel Background="{DynamicResource ThemeAppBackgroundBrush}">
                        <ContentPresenter DockPanel.Dock="Top"
                                          Content="{TemplateBinding HeaderContent}" />

                        <ScrollViewer Margin="5"
                                      Background="{DynamicResource ThemeAppBackgroundBrush}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ContentPresenter Content="{TemplateBinding BodyContent}" />
                        </ScrollViewer>
                    </DockPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
